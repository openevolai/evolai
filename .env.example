# ════════════════════════════════════════════════════════════════════════════════
# EvolAI – Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── HuggingFace (Validator + Miner) ─────────────────────────────────────────
# Required to access gated or private HuggingFace datasets.
# Create a read-only token at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# ── Owner API (Validator only) ───────────────────────────────────────────────
# URL of the public owner gateway.  Leave unchanged unless running a local dev
# instance of the owner stack (e.g. OWNER_API_URL=http://127.0.0.1:8669).
OWNER_API_URL=https://evolai-gate.hf.space

# ── WandB (optional, Validator only) ────────────────────────────────────────
# Weights & Biases API key for experiment tracking.  Leave blank to disable.
# WANDB_API_KEY=
# W&B entity (organization or username) to log runs under.
# WANDB_ENTITY=your-wandb-org

# ── vLLM – Local Deployment (Validator only) ─────────────────────────────────
# Full path to the `vllm` binary when it lives in a separate virtual environment.
# See scripts/setup-validator.sh for the recommended setup.
# VLLM_EXECUTABLE=vllm

# vLLM server ports
# VLLM_JUDGE_PORT=8001
# VLLM_MINER_PORT=8000

# Optional fixed API key for local vLLM servers.
# If not set, a random key is generated at each startup (recommended).
# VLLM_API_KEY=

# GPU configuration
# VLLM_JUDGE_GPU_INDEX=0
# VLLM_MINER_GPU_INDEX=1
# VLLM_JUDGE_GPU_MEMORY_UTILIZATION=0.90
# VLLM_MINER_GPU_MEMORY_UTILIZATION=0.85
# VLLM_JUDGE_TENSOR_PARALLEL_SIZE=1

# Multi-GPU parallel miner slots (4+ GPU setups)
# VLLM_PARALLEL_MINER_GPU_INDICES=1,2,3

# ── Loss Evaluation (Validator only) ────────────────────────────────────────
# Defaults are tuned for 80 GB GPUs (full bf16, Flash Attention, per-size batches).
# Batch size and sequence length are chosen automatically per model size:
#   ~450M  → batch 256, seq 8192     ~1.6B  → batch 128, seq 8192
#   ~3.7B  → batch  64, seq 8192     ~9B    → batch  32, seq 8192
#   ~21B   → batch  16, seq 8192
#
# Override globally (all sizes at once):
# HF_LOSS_BATCH_SIZE=8          # override batch for ALL model sizes
# HF_LOSS_MAX_SEQ_LEN=4096      # override seq length for ALL model sizes
#
# Override per model size (takes precedence over global overrides):
# HF_EVAL_BATCH_450M=256
# HF_EVAL_BATCH_1B6=128
# HF_EVAL_BATCH_3B7=64
# HF_EVAL_BATCH_9B=32
# HF_EVAL_BATCH_21B=16
# HF_EVAL_SEQLEN_450M=8192
# HF_EVAL_SEQLEN_1B6=8192
# HF_EVAL_SEQLEN_3B7=8192
# HF_EVAL_SEQLEN_9B=8192
# HF_EVAL_SEQLEN_21B=8192
#
# Other tuning knobs:
# HF_EVAL_ENABLE_4BIT=false      # set true on < 40 GB GPU
# HF_EVAL_PREFER_FLASH_ATTN=true
# HF_EVAL_TORCH_COMPILE=true     # set false to skip ~60 s compile warmup

# ── Reward / Scoring Tuning (advanced, Validator only) ──────────────────────
# CHALLENGE_WINDOW_SIZE=100
# REWARD_GAMMA=1.0
# REWARD_MAX=1.0
# REWARD_DECAY=0.995
# DIRICHLET_BETA=1.0

# ── Diagnostics (optional) ───────────────────────────────────────────────────
# Set to 1 to write JSONL payload traces for every judge call.
# Traces are written to logs/judge_traces/trace.jsonl — can grow large.
# EVOLAI_TRACE_PAYLOADS=0

# Directory for vLLM server stdout logs (default: system temp directory).
# VLLM_LOG_DIR=/var/log/evolai
